{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip3 install -r requirements.txt || pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "python3 ipshowbot.py",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE"
  }
}
